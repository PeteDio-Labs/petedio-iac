# Terraform
.terraform/
# .terraform.lock.hcl is COMMITTED (PET-108): it pins provider versions +
# checksums so CI applies exactly what was planned/reviewed. Generate with:
#   terraform providers lock -platform=linux_amd64 -platform=darwin_arm64 -platform=darwin_amd64
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Real var files hold secrets / live values — never commit. Example is tracked.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Plan artifacts
tfplan
plan.txt

# Secrets
*.pem
.secrets/
