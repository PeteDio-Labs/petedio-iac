# {{ ansible_managed }}
# Palworld 1.0 dedicated server (PET-157). Installed AND (by default) enabled + started
# by the palworld role, so the server auto-starts on container/host boot. Launch day just
# needs the auto-pulled 1.0 update + a restart:
#   sudo -u {{ palworld_user }} {{ palworld_steamcmd_dir }}/steamcmd.sh \
#     +force_install_dir {{ palworld_server_dir }} +login anonymous \
#     +app_update {{ palworld_steam_app_id }} validate +quit
#   systemctl restart {{ palworld_service_name }}
[Unit]
Description=Palworld dedicated server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ palworld_user }}
Group={{ palworld_group }}
WorkingDirectory={{ palworld_server_dir }}
# -useperfthreads/NoAsyncLoadingThread are Pocketpair's recommended perf flags for
# the dedicated server; the port comes from the templated PalWorldSettings.ini.
# -EnableGameDataAPI: the 1.0 /v1/api/game-data gate is a LAUNCH ARG, not an ini key —
# proven empirically in PET-278 (the ini's EnableGameDataAPI=True alone still 404s).
ExecStart={{ palworld_server_exec }} -useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS{{ ' -EnableGameDataAPI' if palworld_gamedata_api_enabled else '' }}
Restart=on-failure
RestartSec=5
# Give the server time to flush saves on stop rather than getting SIGKILLed.
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
