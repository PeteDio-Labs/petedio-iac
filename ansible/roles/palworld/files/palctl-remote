#!/usr/bin/env bash
# palctl-remote — the forced command for the control panel's restricted SSH key (PET-266).
# root's authorized_keys pins command="/usr/local/bin/palctl-remote", so whatever the panel
# sends arrives in $SSH_ORIGINAL_COMMAND and is allow-listed here — the key can ONLY run these
# verbs, nothing else. Installed by the palworld role (was previously hand-placed drift).
set -euo pipefail

case "${SSH_ORIGINAL_COMMAND:-}" in
  start)        exec systemctl start palworld ;;
  status)       exec systemctl is-active palworld ;;
  check-update) exec /usr/local/bin/palworld-update --check ;;
  update)       exec /usr/local/bin/palworld-update --apply ;;
  *)
    echo "palctl-remote: denied — only start / status / check-update / update are permitted" >&2
    exit 1
    ;;
esac
