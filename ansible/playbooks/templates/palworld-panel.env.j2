# {{ ansible_managed }}
# Backend secret env-file (0600). Read by the palworld-panel.service unit (EnvironmentFile).
PALWORLD_ADMIN_PASSWORD={{ palworld_admin_password }}

# Feature flags (PET-266) — default OFF; the UI hides these when down. Flip to "true"
# to expose. World Settings also needs a GitHub credential (PANEL_GITHUB_TOKEN) to
# actually apply, and per-guild base-limit changes don't take on save-locked 1.0 worlds.
PANEL_ENABLE_WORLD_SETTINGS={{ palworld_panel_enable_world_settings | default('false') }}
PANEL_ENABLE_DEMO={{ palworld_panel_enable_demo | default('false') }}
