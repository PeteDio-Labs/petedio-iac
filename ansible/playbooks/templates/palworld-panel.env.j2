# {{ ansible_managed }}
# Backend secret env-file (0600). Read by the palworld-panel.service unit (EnvironmentFile).
PALWORLD_ADMIN_PASSWORD={{ palworld_admin_password }}

# Feature flags (PET-266) — the UI hides a gated surface when its flag is down.
# Software Update (check for a newer SteamCMD build + apply it from the ⓘ sheet) is on by
# default: it drives the update via the palctl-remote `check-update`/`update` verbs the
# palworld role installs on this host. Demo mode stays off in prod.
PANEL_ENABLE_UPDATE={{ palworld_panel_enable_update | default('true') }}
PANEL_ENABLE_DEMO={{ palworld_panel_enable_demo | default('false') }}

# Session-history dashboard (PET-266). Served ONLY to a browser on the game host itself —
# the backend gates /api/dashboard on the request arriving over loopback, so it is never
# reachable through the Cloudflare tunnel or from elsewhere on the LAN. Turning this off
# disables the endpoint, not just the UI.
PANEL_ENABLE_DASHBOARD={{ palworld_panel_enable_dashboard | default('true') }}
