{# Vault Agent consul-template for the co-latro backend env-file. Ansible renders the
   Jinja bits (PORT); the {% raw %} block is passed through verbatim so Vault Agent's
   consul-template engine resolves DATABASE_URL from kv/poker/db at runtime. The rendered
   file lands on tmpfs ({{ colatro_env_file }}) — the secret is never on persistent disk. -#}
# {{ ansible_managed }} — rendered by Vault Agent from kv/poker/db (PET-57). Do not edit.
NODE_ENV=production
PORT={{ colatro_port }}
{# PET-203 (F7): the backend sits behind nginx (same VM) reached via the Cloudflare tunnel.
   With TRUST_PROXY unset, Express keys the per-IP login limiter on the socket peer (nginx),
   collapsing every client into ONE global bucket — the limiter stops being per-client. Trust
   the nginx hop so req.ip resolves from X-Forwarded-For. NB: validate this hop count against the
   live cloudflared→nginx chain (if cloudflared also appends to XFF the trusted count may be 2);
   keep it an EXACT count, never `true`, so a LAN client hitting the origin directly can't spoof
   X-Forwarded-For to rotate the bucket. -#}
TRUST_PROXY=1
{# PET-201: COLATRO_ADMIN_INVITES_URL/_AUTH activate the admin-issued-invite gate — the login
   gate calls ${URL}/validate against the co-latro-admin `invites` fn (faasd, PET-99). Empty/
   absent = gate off (site stays edge-gated by Cloudflare Access). One read of kv/poker/db. -#}
{% raw %}{{ with secret "kv/data/poker/db" }}DATABASE_URL={{ .Data.data.DATABASE_URL }}
COLATRO_ADMIN_INVITES_URL={{ .Data.data.COLATRO_ADMIN_INVITES_URL }}
COLATRO_ADMIN_INVITES_AUTH={{ .Data.data.COLATRO_ADMIN_INVITES_AUTH }}{{ end }}{% endraw %}
