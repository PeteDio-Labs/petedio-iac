# {{ ansible_managed }}
# Runtime env for the co-latro backend container (mode 0600, root-only).
# DATABASE_URL is injected from Vault kv/poker/db at deploy time (no_log) — never
# committed, never echoed. The backend runs migrations on boot against this DB.
NODE_ENV=production
PORT={{ colatro_port }}
DATABASE_URL={{ colatro_database_url }}
