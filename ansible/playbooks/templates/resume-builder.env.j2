# {{ ansible_managed }}
# App secret/config env-file (0600). Read by the resume-builder.service unit
# (EnvironmentFile).
#
# NODE_ENV=production is good hygiene (and what adapter-node expects), but it is
# NOT the security boundary. The app's dev-only identity-fake escape hatch is gated
# on SvelteKit's BUILD-TIME `dev` constant ($app/environment), which compiles to
# `false` in the production bundle. That was changed deliberately: gating it on a
# runtime NODE_ENV the deploy is not guaranteed to set was a full auth bypass
# (adversarial review, 2026-07-22). Do not re-introduce that dependency.
NODE_ENV=production
PORT={{ resume_builder_port }}
HOST=0.0.0.0
CF_ACCESS_TEAM_DOMAIN={{ resume_builder_cf_access_team_domain }}
CF_ACCESS_AUD={{ resume_builder_cf_access_aud }}
ALLOWED_USERS={{ resume_builder_allowed_users }}
# The password MUST be percent-encoded: a generated password containing '/', '@', ':'
# or '%' otherwise breaks the connection-string parser (the driver fails at
# parseOptions before it ever dials Mongo). Note `urlencode` alone is NOT enough —
# Ansible's filter uses safe='/', so it leaves '/' untouched; the regex_replace closes
# that gap and makes this equivalent to Python's quote(safe='').
MONGODB_URI=mongodb://{{ resume_builder_mongo_user }}:{{ resume_builder_mongo_password | urlencode | regex_replace('/', '%2F') }}@127.0.0.1:{{ resume_builder_mongo_port }}/{{ resume_builder_mongo_db }}?authSource={{ resume_builder_mongo_db }}
MONGODB_DB_NAME={{ resume_builder_mongo_db }}

# --- AI lane (Ollama) ---
# LOAD-BEARING: the app's createAiProvider() falls back to the deterministic demo
# stubs whenever OLLAMA_HOST is empty:
#     if (isDemoMode() || !env('OLLAMA_HOST')) return demoAiProvider();
# so leaving this unset makes a "production" deploy serve fake AI silently.
# Fast lane (:11435, GTX 1660 SUPER) — keyword extraction, span rewrites, embeddings.
OLLAMA_HOST={{ resume_builder_ollama_host }}
OLLAMA_FAST_MODEL={{ resume_builder_ollama_fast_model }}

# Demo mode must stay OFF in production — it swaps the data layer for an in-memory
# store and the AI for deterministic stubs. It is the local/offline test path only.
DEMO_MODE=false
