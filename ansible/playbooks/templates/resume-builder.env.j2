# {{ ansible_managed }}
# App secret/config env-file (0600). Read by the resume-builder.service unit
# (EnvironmentFile). NODE_ENV=production is load-bearing, not cosmetic: the app's
# dev-only identity-fake escape hatch (src/lib/server/auth.ts) gates on it — see
# resume-builder planning doc P1 task-13 note.
NODE_ENV=production
PORT={{ resume_builder_port }}
HOST=0.0.0.0
CF_ACCESS_TEAM_DOMAIN={{ resume_builder_cf_access_team_domain }}
CF_ACCESS_AUD={{ resume_builder_cf_access_aud }}
ALLOWED_USERS={{ resume_builder_allowed_users }}
MONGODB_URI=mongodb://{{ resume_builder_mongo_user }}:{{ resume_builder_mongo_password }}@127.0.0.1:{{ resume_builder_mongo_port }}/{{ resume_builder_mongo_db }}?authSource={{ resume_builder_mongo_db }}
MONGODB_DB_NAME={{ resume_builder_mongo_db }}
